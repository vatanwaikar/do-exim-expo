{
  "project": {
    "supabase_url": "${NEXT_PUBLIC_SUPABASE_URL}",
    "service_role_key": "${SUPABASE_SERVICE_ROLE_KEY}",
    "description": "DoExim Expo - Enterprise Trade Show Platform"
  },
  "storage_buckets": [
    {
      "name": "logos",
      "public": false,
      "allowed_mime_types": [
        "image/jpeg",
        "image/png",
        "image/webp",
        "image/svg+xml"
      ],
      "max_file_size": 5242880,
      "description": "Company logos (max 5MB)"
    },
    {
      "name": "brochures",
      "public": false,
      "allowed_mime_types": [
        "application/pdf",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      ],
      "max_file_size": 52428800,
      "description": "Company brochures (max 50MB)"
    },
    {
      "name": "gallery",
      "public": false,
      "allowed_mime_types": [
        "image/jpeg",
        "image/png",
        "image/webp",
        "video/mp4"
      ],
      "max_file_size": 104857600,
      "description": "Event gallery images and videos (max 100MB)"
    },
    {
      "name": "speakers",
      "public": false,
      "allowed_mime_types": [
        "image/jpeg",
        "image/png",
        "image/webp"
      ],
      "max_file_size": 10485760,
      "description": "Speaker photos (max 10MB)"
    },
    {
      "name": "documents",
      "public": false,
      "allowed_mime_types": [
        "application/pdf",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      ],
      "max_file_size": 52428800,
      "description": "Event documents (max 50MB)"
    }
  ],
  "authentication": {
    "providers": {
      "email": {
        "enabled": true,
        "confirm_email": true,
        "double_confirm_changes": false,
        "auto_confirm_users": false
      },
      "oauth": {
        "google": false,
        "github": false,
        "linkedin": false
      }
    },
    "session_expiry": 3600000,
    "refresh_token_rotation_enabled": true
  },
  "rls_policies": {
    "enabled": true,
    "enforce": true,
    "description": "Comprehensive Row Level Security for multi-tenant security"
  },
  "backups": {
    "enabled": true,
    "frequency": "daily",
    "retention_days": 30
  },
  "monitoring": {
    "performance_monitoring": true,
    "error_tracking": true,
    "audit_logs": true
  }
}
